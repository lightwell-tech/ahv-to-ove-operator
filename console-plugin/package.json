{
  "name": "ahv-to-ove-console-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "webpack serve --config webpack.config.js",
    "build": "webpack --config webpack.config.js && node scripts/patch-manifest.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@openshift-console/dynamic-plugin-sdk": "^4.22.0",
    "@patternfly/react-core": "^5.3.3",
    "@patternfly/react-icons": "^5.3.3",
    "@patternfly/react-table": "^5.3.3",
    "ajv": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk-webpack": "^4.22.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "css-loader": "^6.11.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "webpack": "^5.75.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.11.1"
  },
  "consolePlugin": {
    "name": "ahv-to-ove-plugin",
    "version": "0.1.0",
    "displayName": "AHV to OVE Migration",
    "description": "Nutanix AHV から OpenShift Virtualization への VM 移行管理",
    "exposedModules": {
      "MigrationListPage": "./components/MigrationListPage",
      "MigrationDetailPage": "./components/MigrationDetailPage",
      "MigrationCreatePage": "./components/MigrationCreatePage"
    },
    "dependencies": {
      "@console/pluginAPI": ">=4.14.0"
    }
  }
}
